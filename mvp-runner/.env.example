# 飞书应用凭据
LARK_APP_ID=cli_a9645d1646a31bc9
LARK_APP_SECRET=X56MxRXD6fAvHmi0SkJlkdHTVq62Ulum
LARK_CHAT_ID=oc_9f741c1f2d5b1fc1e98a0b42c04283c5
LARK_MENTION_KEYWORD=PMCLI

# Trae CDP 调试端口
CDP_HOST=localhost
CDP_PORT=9222

# 调试日志命名空间
DEBUG=mvp:*

# ──────────────────────────────────────────────
# WikiBot 配置（LLM Wiki v2.0）
# ──────────────────────────────────────────────

# 是否启用WikiBot（true/false）
WIKIBOT_ENABLED=false

# WikiBot专用飞书账号ID（用于接收调度任务）
WIKIBOT_LARK_USER_ID=ou_xxxxxxxxxxxxxxxxx

# 调度脚本的飞书ID（WikiBot只接受来自此ID的消息）
SCHEDULER_LARK_USER_ID=ou_yyyyyyyyyyyyyyy

# WikiBot消息前缀过滤
WIKIBOT_REQUIRED_PREFIX=@WikiBot

# WikiBot专用Slot编号（避开PMCLI/DEVCLI的Slot 0/1）
WIKIBOT_SLOT_INDEX=2

# 允许触发WikiBot的Sender列表（逗号分隔，空表示允许所有人）
WIKIBOT_ALLOWED_SENDERS=

# 蒸馏任务超时（毫秒，默认10分钟）
WIKIBOT_DISTILL_TIMEOUT=600000

# 合并任务超时（毫秒，默认2分钟）
WIKIBOT_MERGE_TIMEOUT=120000

# LLM API配置（用于wiki-distill和wiki-merge）
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com
DISTILL_MODEL=gpt-4o-mini
MERGE_MODEL=gpt-4o-mini
