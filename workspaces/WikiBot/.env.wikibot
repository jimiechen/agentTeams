# WikiBot 专用飞书账号 ID（用于接收调度任务）
WIKIBOT_LARK_USER_ID=ou_xxxxxxxxxxxxxxxxx

# 调度脚本的飞书 ID（WikiBot 只接受来自此 ID 的消息）
SCHEDULER_LARK_USER_ID=ou_yyyyyyyyyyyyyyy

# LLM 配置（用于 wiki-distill 和 wiki-merge）
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com

# 蒸馏模型配置
DISTILL_MODEL=gpt-4o-mini

# 合并模型配置
MERGE_MODEL=gpt-4o-mini
